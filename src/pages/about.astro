---
import Layout from '../layouts/Layout.astro'
import data from '../data/about.json'
---

<Layout title="關於醫師 - 吳文綺醫師" description="吳文綺醫師的個人經歷、學歷、專長與專業證照">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-[#FFFAF5] via-[#FDF8F3] to-[#F5E6D3] py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
          <div class="aspect-[4/5] rounded-3xl overflow-hidden">
            <img src="/dr-wu-photo.jpg" alt="吳文綺醫師" class="w-full h-full object-cover" />
          </div>
        <div class="space-y-6">
          <div class="inline-flex items-center gap-2 bg-[#D4856A]/10 px-4 py-2 rounded-full text-[#D4856A] text-sm">
            <span class="w-2 h-2 rounded-full bg-[#D4856A]"></span>
            {data.hero.badge}
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-[#4A3728]">
            {data.hero.name}
          </h1>
          <p class="text-xl text-[#D4856A] font-medium">{data.hero.position}</p>
          <p class="text-[#8B6F5C] text-lg leading-relaxed">
            {data.hero.description}
          </p>
          <div class="flex flex-wrap gap-3 pt-4">
            {data.hero.certifications.map((cert) => (
              <span class="px-4 py-2 bg-white rounded-full text-sm text-[#8B6F5C] shadow-sm">{cert}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Details -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 space-y-12">
      <!-- 現任 -->
      <div>
        <h2 class="text-2xl font-bold text-[#4A3728] mb-6 flex items-center gap-3">
          <span class="w-8 h-8 rounded-lg bg-[#D4856A] flex items-center justify-center text-white text-sm">1</span>
          現任
        </h2>
        <div class="warm-card ml-4 border-l-4 border-[#D4856A]">
          <ul class="space-y-2 text-[#8B6F5C]">
            {data.current.map((item) => (
              <li class="flex items-start gap-2">
                <span class="text-[#D4856A] mt-1">●</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- 學歷 -->
      <div>
        <h2 class="text-2xl font-bold text-[#4A3728] mb-6 flex items-center gap-3">
          <span class="w-8 h-8 rounded-lg bg-[#D4856A] flex items-center justify-center text-white text-sm">2</span>
          學歷
        </h2>
        <div class="warm-card ml-4 border-l-4 border-[#D4856A]">
          <ul class="space-y-2 text-[#8B6F5C]">
            {data.education.map((item) => (
              <li class="flex items-start gap-2">
                <span class="text-[#D4856A] mt-1">●</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- 經歷 -->
      <div>
        <h2 class="text-2xl font-bold text-[#4A3728] mb-6 flex items-center gap-3">
          <span class="w-8 h-8 rounded-lg bg-[#D4856A] flex items-center justify-center text-white text-sm">3</span>
          經歷
        </h2>
        <div class="warm-card ml-4 border-l-4 border-[#D4856A]">
          <ul class="space-y-2 text-[#8B6F5C]">
            {data.experience.map((item) => (
              <li class="flex items-start gap-2">
                <span class="text-[#D4856A] mt-1">●</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- 專長 -->
      <div>
        <h2 class="text-2xl font-bold text-[#4A3728] mb-6 flex items-center gap-3">
          <span class="w-8 h-8 rounded-lg bg-[#D4856A] flex items-center justify-center text-white text-sm">4</span>
          專長
        </h2>
        <div class="warm-card ml-4 border-l-4 border-[#D4856A]">
          <ul class="space-y-2 text-[#8B6F5C]">
            {data.specialties.map((item) => (
              <li class="flex items-start gap-2">
                <span class="text-[#D4856A] mt-1">●</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</Layout>
