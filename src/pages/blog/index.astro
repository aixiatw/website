---
import Layout from '../../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
---
<Layout title="衛教文章 - 吳文綺醫師" description="吳文綺醫師的衛教文章，分享婦產科醫療新知與健康資訊">
  <section class="bg-gradient-to-br from-[#FFFAF5] via-[#FDF8F3] to-[#F5E6D3] py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-[#4A3728] mb-4">衛教文章</h1>
        <p class="text-[#8B6F5C] text-lg">關心女性健康，分享醫療新知</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="warm-card group">
            <div class="aspect-[16/10] rounded-xl bg-gradient-to-br from-[#F5E6D3] to-[#E8D5C4] mb-4 flex items-center justify-center overflow-hidden">
              <svg class="w-12 h-12 text-[#D4856A] opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
              </svg>
            </div>
            <div class="flex items-center gap-3 mb-3">
              <span class="px-3 py-1 bg-[#D4856A]/10 text-[#D4856A] text-xs rounded-full">{post.data.category}</span>
              <span class="text-xs text-[#8B6F5C]">{post.data.date.toLocaleDateString('zh-TW')}</span>
            </div>
            <h2 class="text-xl font-semibold text-[#4A3728] mb-2 group-hover:text-[#D4856A] transition-colors">{post.data.title}</h2>
            <p class="text-sm text-[#8B6F5C] leading-relaxed">{post.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>